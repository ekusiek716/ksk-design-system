{
  "meta": {
    "name": "KSK Design System",
    "version": "1.0.0",
    "description": "フリーランス向けマルチテーマ対応デザインシステム"
  },
  "colors": {
    "primitive": {
      "brand": {
        "50": "#EFF6FF", "100": "#DBEAFE", "200": "#BFDBFE", "300": "#93C5FD",
        "400": "#60A5FA", "500": "#3B82F6", "600": "#2563EB", "700": "#1D4ED8",
        "800": "#1E40AF", "900": "#1E3A8A"
      },
      "gray": {
        "50": "#F9FAFB", "100": "#F3F4F6", "200": "#E5E7EB", "300": "#D1D5DB",
        "400": "#9CA3AF", "500": "#6B7280", "600": "#4B5563", "700": "#374151",
        "800": "#1F2937", "900": "#111827"
      },
      "red": {
        "50": "#FEF2F2", "100": "#FEE2E2", "200": "#FECACA", "300": "#FCA5A5",
        "400": "#F87171", "500": "#EF4444", "600": "#DC2626", "700": "#B91C1C",
        "800": "#991B1B", "900": "#7F1D1D"
      },
      "green": {
        "50": "#F0FDF4", "100": "#DCFCE7", "200": "#BBF7D0", "300": "#86EFAC",
        "400": "#4ADE80", "500": "#22C55E", "600": "#16A34A", "700": "#15803D",
        "800": "#166534", "900": "#14532D"
      }
    },
    "semantic": {
      "surface": {
        "primary": "var(--Primitive-White)",
        "secondary": "var(--Primitive-Gray-50)",
        "tertiary": "var(--Primitive-Gray-100)"
      },
      "text": {
        "high-emphasis": "var(--Primitive-Gray-900)",
        "medium-emphasis": "var(--Primitive-Gray-700)",
        "low-emphasis": "var(--Primitive-Gray-500)",
        "on-inverse": "var(--Primitive-White)",
        "accent-primary": "var(--Primitive-Brand-600)"
      },
      "brand": {
        "primary": "var(--Primitive-Brand-500)",
        "action": "var(--Primitive-Brand-700)"
      },
      "focus": {
        "high-emphasis": "#1FCC84"
      }
    }
  },
  "typography": {
    "heading": {
      "3xl": { "size": "28px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "2xl": { "size": "24px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "xl":  { "size": "21px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "lg":  { "size": "18px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "md":  { "size": "16px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "sm":  { "size": "14px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" }
    },
    "body": {
      "lg": { "size": "16px", "weight": 400, "lineHeight": 1.75 },
      "md": { "size": "14px", "weight": 400, "lineHeight": 1.75 },
      "sm": { "size": "12px", "weight": 400, "lineHeight": 1.5 },
      "xs": { "size": "10px", "weight": 400, "lineHeight": 1.5 }
    },
    "label": {
      "lg": { "size": "16px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "md": { "size": "14px", "weight": 700, "lineHeight": 1.5, "letterSpacing": "0.04em" },
      "sm": { "size": "12px", "weight": 500, "lineHeight": 1.5 },
      "xs": { "size": "10px", "weight": 500, "lineHeight": 1.5 }
    },
    "display": {
      "xl": { "size": "48px", "weight": 700, "lineHeight": 1.25, "letterSpacing": "-0.02em" },
      "lg": { "size": "36px", "weight": 700, "lineHeight": 1.3, "letterSpacing": "-0.01em" }
    },
    "caption": { "size": "11px", "weight": 400, "lineHeight": 1.5 }
  },
  "spacing": {
    "unit": "4px",
    "scale": [0, 4, 8, 12, 16, 20, 24, 28, 32, 36, 40, 44, 48, 52, 56, 60]
  },
  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "lg": "8px",
    "2xl": "16px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 0 8px rgba(20, 20, 20, 0.08)",
    "lg": "0px 12px 32px -4px rgba(24, 39, 75, 0.12), 0px 8px 16px -6px rgba(24, 39, 75, 0.12)",
    "dialog": "0px 12px 32px -4px rgba(24, 39, 75, 0.12), 0px 8px 16px -6px rgba(24, 39, 75, 0.12), 0px 1px 4px 1px rgba(0, 0, 0, 0.2)",
    "tooltip": "0px 8px 8px -4px rgba(24, 39, 75, 0.08), 0px 4px 6px -4px rgba(24, 39, 75, 0.12)"
  },
  "touchTargets": {
    "buttonCTA": { "min": "40px", "recommended": "48px" },
    "iconButton": { "min": "40px", "recommended": "44px" },
    "textInput": { "min": "44px", "recommended": "48px" },
    "chip": { "min": "32px", "recommended": "36px" },
    "navItem": { "min": "44px", "recommended": "48px" }
  },
  "themes": {
    "default": { "brand500": "#3B82F6", "label": "Default (Blue)" },
    "orange": { "brand500": "#E04B00", "label": "Orange (EC)" },
    "green": { "brand500": "#16A34A", "label": "Green (Healthcare)" },
    "violet": { "brand500": "#7C3AED", "label": "Violet (Premium)" }
  }
}
