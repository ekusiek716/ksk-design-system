{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/class-names.ts",
    "src/components/**/*.tsx",
    "src/lib/**/*.ts",
    "src/tokens/native/**/*.ts",
    "src/native/**/*.ts",
    "src/native/**/*.tsx"
  ],
  "exclude": ["src/**/*.stories.tsx", "src/**/*.test.tsx"]
}
