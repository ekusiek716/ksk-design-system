{
  "rules": [
    {
      "id": "text-001",
      "category": "text",
      "level": "warn",
      "pattern": "font-bold|font-semibold|font-medium|font-light",
      "message": "個別のfont-weightは禁止。typo-* クラスを使用してください",
      "fix": "typo-label-md, typo-heading-md 等"
    },
    {
      "id": "text-002",
      "category": "text",
      "level": "warn",
      "pattern": "text-\\[[0-9]+px\\]",
      "message": "text-[Npx] は禁止。typo-* クラスを使用してください",
      "fix": "typo-body-md, typo-heading-lg 等"
    },
    {
      "id": "color-001",
      "category": "color",
      "level": "warn",
      "pattern": "text-white|bg-white",
      "message": "Tailwind標準色は禁止",
      "fix": "text-[var(--Text-on-Inverse)], bg-[var(--Surface-Primary)]"
    },
    {
      "id": "color-002",
      "category": "color",
      "level": "warn",
      "pattern": "text-black|bg-black",
      "message": "純黒は禁止。コントラストが強すぎる",
      "fix": "text-[var(--Text-High-Emphasis)]"
    },
    {
      "id": "color-003",
      "category": "color",
      "level": "warn",
      "pattern": "text-gray-|bg-gray-|text-blue-|bg-blue-|text-red-|bg-red-",
      "message": "Tailwind標準色は禁止。セマンティックトークンを使用",
      "fix": "var(--Text-*), var(--Surface-*), var(--Brand-*)"
    },
    {
      "id": "color-004",
      "category": "color",
      "level": "warn",
      "pattern": "#[0-9A-Fa-f]{6}",
      "message": "HEX直書きは禁止。セマンティックトークンを使用",
      "fix": "var(--Brand-Primary) 等"
    },
    {
      "id": "component-001",
      "category": "component",
      "level": "error",
      "pattern": "<button(?!.*data-slot)",
      "message": "生の <button> は禁止。<Button> コンポーネントを使用",
      "fix": "<Button variant=\"default\" size=\"default\">"
    },
    {
      "id": "component-002",
      "category": "component",
      "level": "error",
      "pattern": "<input(?!.*data-slot)",
      "message": "生の <input> は禁止。<Input> コンポーネントを使用",
      "fix": "<Input type=\"text\" />"
    },
    {
      "id": "component-003",
      "category": "component",
      "level": "error",
      "pattern": "<a href",
      "message": "生の <a> は禁止。<Button variant=\"link\"> を使用",
      "fix": "<Button variant=\"link\">"
    },
    {
      "id": "layout-001",
      "category": "layout",
      "level": "warn",
      "pattern": "rounded-md|rounded-xl|rounded-3xl",
      "message": "DS定義外の角丸。rounded-none/sm/lg/2xl/full のみ使用可能",
      "fix": "rounded-sm (4px), rounded-lg (8px), rounded-2xl (16px), rounded-full"
    },
    {
      "id": "layout-002",
      "category": "layout",
      "level": "warn",
      "pattern": "shadow-md|shadow-lg|shadow-xl|shadow-2xl",
      "message": "DS定義外のシャドウ。shadow-[var(--shadow-*)] を使用",
      "fix": "shadow-[var(--shadow-md)], shadow-[var(--shadow-dialog)]"
    },
    {
      "id": "layout-003",
      "category": "layout",
      "level": "warn",
      "pattern": "border-t-4|border-l-4|border-r-4|border-b-4",
      "message": "カラーバーはAI生成パターン。全周ボーダーを使用",
      "fix": "border border-[var(--Border-Low-Emphasis)]"
    },
    {
      "id": "layout-004",
      "category": "layout",
      "level": "warn",
      "pattern": "bg-gradient-to-",
      "message": "グラデーションはDS定義外。単色背景を使用",
      "fix": "bg-[var(--Surface-*)]"
    },
    {
      "id": "layout-005",
      "category": "layout",
      "level": "warn",
      "pattern": "z-\\[9999\\]|z-\\[999\\]",
      "message": "過剰なz-index。z-50を使用",
      "fix": "z-50"
    },
    {
      "id": "a11y-001",
      "category": "a11y",
      "level": "warn",
      "pattern": "outline-none(?!.*focus-visible)",
      "message": "outline-noneはフォーカスリングを消す。focus-visible:ringで代替",
      "fix": "focus-visible:ring-[3px] focus-visible:ring-[var(--Focus-High-Emphasis)]/50"
    }
  ]
}
