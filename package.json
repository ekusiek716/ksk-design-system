{
  "name": "@ksk/design-system",
  "version": "1.15.2",
  "type": "module",
  "description": "KSK Design System — フリーランス向けマルチテーマ対応デザインシステム",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "ksk-ds": "./bin/init.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "contracts",
    "tokens.json",
    "AGENTS.md",
    "CLAUDE.md",
    "src/preset.css",
    "src/preset-standalone.css",
    "src/styles",
    "src/themes",
    "src/components/COMPONENT_LOOKUP.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./class-names": {
      "types": "./dist/types/class-names.d.ts",
      "import": "./dist/class-names.js",
      "default": "./dist/class-names.js"
    },
    "./package.json": "./package.json",
    "./preset": "./src/preset.css",
    "./preset-standalone": "./src/preset-standalone.css",
    "./styles": "./src/preset.css",
    "./tokens/primitive": "./src/styles/primitive.css",
    "./tokens/semantic": "./src/styles/semantic.css",
    "./tokens/typography": "./src/styles/typography.css",
    "./themes/default": "./src/themes/default.css",
    "./themes/blue": "./src/themes/blue.css",
    "./themes/orange": "./src/themes/orange.css",
    "./themes/green": "./src/themes/green.css",
    "./themes/violet": "./src/themes/violet.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --project tsconfig.lib.json || true",
    "prepack": "npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6010",
    "build-storybook": "storybook build",
    "lint:scratch": "bash scripts/lint-scratch.sh",
    "generate:lookup": "node scripts/generate-component-lookup.mjs",
    "check": "tsc --noEmit && bash scripts/lint-scratch.sh && bash scripts/check-drift.sh && node scripts/generate-component-lookup.mjs",
    "postinstall": "node bin/init.js postinstall",
    "mcp:build": "cd mcp-server && npm install && npm run build",
    "mcp:start": "node mcp-server/dist/index.js"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "@radix-ui/react-slot": "^1.0.0",
    "iconsax-reactjs": "^0.0.8",
    "radix-ui": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "iconsax-reactjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^16.5.0",
    "iconsax-reactjs": "^0.0.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "zod": "^4.4.2"
  }
}
